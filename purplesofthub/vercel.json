{
  "version": 2,
  "name": "purplesofthub",
  "buildCommand": "NODE_OPTIONS='--max-old-space-size=4096' next build",
  "env": {
    "NODE_OPTIONS": "--max-old-space-size=4096"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/app"
    }
  ],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    }
  }
}