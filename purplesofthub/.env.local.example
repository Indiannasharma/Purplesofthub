# ─── Supabase ──────────────────────────────────────────
# Get these from: https://supabase.com/dashboard/project/<your-project>/settings/api-keys/legacy
NEXT_PUBLIC_SUPABASE_URL=https://<your-project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Site URL ──────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://purplesofthub.com/

# Nova AI provider
NOVA_AI_PROVIDER=openrouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-5.5
OPENROUTER_REASONING_EFFORT=medium

# Anthropic can still be used by setting NOVA_AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Nova website agent -> Softclaw Railway alerts
SOFTCLAW_NOVA_ALERT_URL=https://your-softclaw-railway-domain/nova/alert
SOFTCLAW_NOVA_ALERT_SECRET=use_a_long_random_shared_secret

# ─── Nodemailer (Gmail) ────────────────────────────────
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_TO=your_email@gmail.com

# ─── Paystack ──────────────────────────────────────────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public_key
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret_key

# ─── Cloudinary ────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── Upstash Redis ─────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token

# ─── Cloudflare Turnstile ──────────────────────────────
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your_turnstile_site_key
TURNSTILE_SECRET_KEY=your_turnstile_secret_key

# ─── Google Analytics ──────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
